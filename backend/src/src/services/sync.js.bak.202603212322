const db = require('../db');
const QianChuanAPI = require('./qianchuan');
const { sendAlert } = require('./notify');
const logger = require('../logger');
const dayjs = require('dayjs');

async function getActiveAccounts() {
  const [rows] = await db.query(
    'SELECT *, COALESCE(account_type, "product") AS account_type FROM qc_accounts WHERE status=1 AND access_token IS NOT NULL AND access_token != ""'
  );
  return rows;
}

function extractUniMetrics(metricsObj) {
  const get = (key) => {
    const m = metricsObj[key];
    return m ? (m.Value || 0) : 0;
  };
  return {
    cost: parseFloat(get('stat_cost')) || 0,
    orders: parseInt(get('total_pay_order_count_for_roi2')) || 0,
    gmv: parseFloat(get('total_pay_order_gmv_for_roi2')) || 0,
    gmvWithCoupon: parseFloat(get('total_pay_order_gmv_include_coupon_for_roi2')) || 0,
    costPerOrder: parseFloat(get('total_cost_per_pay_order_for_roi2')) || 0,
    roi: parseFloat(get('total_prepay_and_pay_order_roi2')) || 0
  };
}

async function syncDailyStats(account, date) {
  const api = new QianChuanAPI(account.access_token);
  const dateStr = date || dayjs().format('YYYY-MM-DD');
  logger.info('[Sync] 同步账户 ' + account.advertiser_id + ' 日期 ' + dateStr);

  try {
    const res = await api.getUniPromotionReport({
      advertiserId: account.advertiser_id,
      startDate: dateStr,
      endDate: dateStr,
      pageSize: 200
    });

    const rows = (res && res.data && res.data.rows) ? res.data.rows : [];
    logger.info('[Sync] 账户 ' + account.advertiser_id + ' 获取到 ' + rows.length + ' 条全域推广数据');

    let totalCost = 0, totalOrders = 0, totalGmv = 0, totalGmvWithCoupon = 0;

    for (const row of rows) {
      const dims = row.dimensions || {};
      const mets = row.metrics || {};
      const adId = (dims.ad_id && dims.ad_id.ValueStr) ? String(dims.ad_id.ValueStr) : '';
      const dayStr = (dims.stat_time_day && dims.stat_time_day.ValueStr) ? dims.stat_time_day.ValueStr : dateStr;
      if (!adId) continue;

      const { cost, orders, gmv, gmvWithCoupon, costPerOrder, roi } = extractUniMetrics(mets);
      totalCost += cost;
      totalOrders += orders;
      totalGmv += gmv;
      totalGmvWithCoupon += gmvWithCoupon;

      await upsertDailyStat(account.advertiser_id, dayStr, 'campaign', adId, adId, {
        cost, orders, gmv: gmvWithCoupon, gmvNoCoupon: gmv, costPerOrder, roi
      });
    }

    if (rows.length > 0) {
      const accountRoi = totalCost > 0 ? totalGmvWithCoupon / totalCost : 0;
      const avgCostPerOrder = totalOrders > 0 ? totalCost / totalOrders : 0;
      await upsertDailyStat(
        account.advertiser_id, dateStr, 'account',
        String(account.advertiser_id),
        account.advertiser_name || '账户汇总',
        { cost: totalCost, orders: totalOrders, gmv: totalGmvWithCoupon, gmvNoCoupon: totalGmv, costPerOrder: avgCostPerOrder, roi: accountRoi }
      );
    }

    await db.query('UPDATE qc_accounts SET last_sync_at=NOW() WHERE advertiser_id=?', [account.advertiser_id]);
    logger.info('[Sync] 账户 ' + account.advertiser_id + ' 计划同步完成，' + rows.length + '条，消耗' + totalCost.toFixed(2));
  } catch (e) {
    logger.error('[Sync] 账户 ' + account.advertiser_id + ' 同步失败', { error: e.message });
  }
}

async function upsertDailyStat(advertiserId, statDate, entityType, entityId, entityName, data) {
  if (!entityId) return;
  const sql = 'INSERT INTO qc_daily_stats (advertiser_id,stat_date,entity_type,entity_id,entity_name,cost,show_cnt,click_cnt,ctr,convert_cnt,convert_rate,convert_cost,cpm,gmv_no_coupon,cpc,play_over_rate,dy_follow) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?) ON DUPLICATE KEY UPDATE entity_name=VALUES(entity_name),cost=VALUES(cost),convert_cnt=VALUES(convert_cnt),convert_rate=VALUES(convert_rate),convert_cost=VALUES(convert_cost),cpm=VALUES(cpm),gmv_no_coupon=VALUES(gmv_no_coupon),updated_at=NOW()';
  await db.query(sql, [
    advertiserId, statDate, entityType, entityId, entityName,
    parseFloat(data.cost || 0), 0, 0, 0,
    parseInt(data.orders || 0), parseFloat(data.roi || 0),
    parseFloat(data.costPerOrder || 0), parseFloat(data.gmv || 0), parseFloat(data.gmvNoCoupon || 0), 0, 0, 0
  ]);
}



/**
 * 同步直播全域账户数据（通过 uni_promotion/list 端点）
 * uni_promotion/list 返回的金额单位为 1/100000 元，需要除以 100000 转换
 */
async function syncLiveDailyStats(account, date) {
  const api = new QianChuanAPI(account.access_token);
  const dateStr = date || dayjs().format("YYYY-MM-DD");
  logger.info("[Sync] 同步直播全域账户 " + account.advertiser_id + " 日期 " + dateStr);

  try {
    const res = await api.getLivePromotionList({
      advertiserId: account.advertiser_id,
      startDate: dateStr,
      endDate: dateStr,
      marketingGoal: "LIVE_PROM_GOODS",
      pageSize: 100
    });

    const adList = (res && res.data && res.data.ad_list) ? res.data.ad_list : [];
    logger.info("[Sync] 直播账户 " + account.advertiser_id + " 获取到 " + adList.length + " 条推广计划");

    let totalCost = 0, totalOrders = 0, totalGmv = 0, totalGmvWithCoupon = 0;
    const UNIT = 100000; // uni_promotion/list 金额单位转换因子

    for (const ad of adList) {
      const info = ad.ad_info || {};
      const stats = ad.stats_info || {};
      const adId = String(info.id || "");
      if (!adId) continue;

      const cost = (parseFloat(stats.stat_cost) || 0) / UNIT;
      const orders = parseInt(stats.total_pay_order_count_for_roi2) || 0;
      const gmv = (parseFloat(stats.total_pay_order_gmv_for_roi2) || 0) / UNIT;
      const costPerOrder = (parseFloat(stats.total_cost_per_pay_order_for_roi2) || 0) / UNIT;
      const roi = parseFloat(stats.total_prepay_and_pay_order_roi2) || 0;

      totalCost += cost;
      totalOrders += orders;
      totalGmv += gmv;
      const gmvWithCoupon = (parseFloat(stats.total_pay_order_gmv_include_coupon_for_roi2) || 0) / UNIT;
      totalGmvWithCoupon += gmvWithCoupon;

      // 计划名包含主播信息
      const roomInfo = (ad.room_info && ad.room_info[0]) ? ad.room_info[0] : {};
      const entityName = (roomInfo.anchor_name || "") + " - " + (info.name || adId);

      await upsertDailyStat(account.advertiser_id, dateStr, "campaign", adId, entityName, {
        cost, orders, gmv: gmvWithCoupon, gmvNoCoupon: gmv, costPerOrder, roi
      });
    }

    if (adList.length > 0) {
      const accountRoi = totalCost > 0 ? totalGmvWithCoupon / totalCost : 0;
      const avgCostPerOrder = totalOrders > 0 ? totalCost / totalOrders : 0;
      await upsertDailyStat(
        account.advertiser_id, dateStr, "account",
        String(account.advertiser_id),
        account.advertiser_name || "账户汇总",
        { cost: totalCost, orders: totalOrders, gmv: totalGmvWithCoupon, gmvNoCoupon: totalGmv, costPerOrder: avgCostPerOrder, roi: accountRoi }
      );
    }

    await db.query("UPDATE qc_accounts SET last_sync_at=NOW() WHERE advertiser_id=?", [account.advertiser_id]);
    logger.info("[Sync] 直播账户 " + account.advertiser_id + " 同步完成，" + adList.length + "条计划，消耗" + totalCost.toFixed(2));
  } catch (e) {
    logger.error("[Sync] 直播账户 " + account.advertiser_id + " 同步失败", { error: e.message });
  }
}

/**
 * 同步视频素材级别数据（全域推广模式）
 */
async function syncMaterialStats(account, date) {
  const api = new QianChuanAPI(account.access_token);
  const dateStr = date || dayjs().format('YYYY-MM-DD');
  logger.info('[Sync] 同步素材数据 账户 ' + account.advertiser_id + ' 日期 ' + dateStr + ' type=' + account.account_type);

  const allMaterials = new Map();

  // 直播账户使用 SITE_PROMOTION_POST_DATA_VIDEO + 必填筛选
  if (account.account_type === 'live') {
    try {
      // 获取授权的抖音号列表
      const awemeList = await api.getAuthorizedAweme(account.advertiser_id);
      const liveAwemes = awemeList.filter(a => a.aweme_has_live_permission);
      logger.info('[Sync] 直播账户 ' + account.advertiser_id + ' 有 ' + liveAwemes.length + ' 个直播抖音号');

      // 对每个有直播权限的抖音号 + 每种投放类型查询素材数据
      const smartBidTypes = ['0', '7']; // 控成本投放, 放量投放
      const ecpAppIds = ['1', '2'];     // 千川PC, 小店随心推

      for (const aweme of liveAwemes) {
        for (const bidType of smartBidTypes) {
          for (const ecpId of ecpAppIds) {
            let page = 1;
            let hasMore = true;
            while (hasMore) {
              // 防止API频率超限 - 间隔800ms
              await new Promise(r => setTimeout(r, 800));
              let res;
              let retryCount = 0;
              while (retryCount < 3) {
                res = await api.getLiveVideoMaterialReport({
                  advertiserId: account.advertiser_id,
                  startDate: dateStr,
                  endDate: dateStr,
                  anchorId: String(aweme.aweme_id),
                  smartBidType: bidType,
                  ecpAppId: ecpId,
                  page,
                  pageSize: 200
                });
                if (res.code === 40100) {
                  retryCount++;
                  logger.warn('[Sync] API频率超限，第' + retryCount + '次重试，等待' + (retryCount * 2) + '秒...');
                  await new Promise(r => setTimeout(r, retryCount * 2000));
                } else {
                  break;
                }
              }
              const rows = (res && res.data && res.data.rows) ? res.data.rows : [];
              if (rows.length === 0) { hasMore = false; break; }

              for (const row of rows) {
                const dims = row.dimensions || {};
                const mets = row.metrics || {};
                const materialId = dims.material_id ? String(dims.material_id.ValueStr || dims.material_id.Value || '') : '';
                const videoName = dims.roi2_material_video_name ? String(dims.roi2_material_video_name.ValueStr || dims.roi2_material_video_name.Value || '') : '';
                if (!materialId || materialId === '-2' || materialId === '0') continue;

                const getVal = (key) => { const m = mets[key]; return m ? (m.Value || 0) : 0; };
                const cost = parseFloat(getVal('stat_cost_for_roi2')) || 0;
                const orders = parseInt(getVal('total_pay_order_count_for_roi2')) || 0;
                const gmv = parseFloat(getVal('total_pay_order_gmv_for_roi2')) || 0;
                const costPerOrder = parseFloat(getVal('total_cost_per_pay_order_for_roi2')) || 0;
                const roi = parseFloat(getVal('total_prepay_and_pay_order_roi2')) || 0;
                const gmvWithCoupon = parseFloat(getVal('total_pay_order_gmv_include_coupon_for_roi2')) || 0;
                const showCount = parseInt(getVal('live_show_count_for_roi2_v2')) || 0;
                const clickCount = parseInt(getVal('live_watch_count_for_roi2_v2')) || 0;
                const ctr = parseFloat(getVal('live_cvr_rate_for_roi2_v2')) || 0;
                const convertRate = parseFloat(getVal('live_convert_rate_for_roi2_v2')) || 0;
                const videoPlayCount = parseInt(getVal('video_play_count_for_roi2_v2')) || 0;
                const videoFinishRate = parseFloat(getVal('video_play_finish_rate_for_roi2_v2')) || 0;

                // 合并同一素材的多个查询结果（不同anchor/bidType/ecp可能有重叠）
                if (allMaterials.has(materialId)) {
                  const existing = allMaterials.get(materialId);
                  existing.cost += cost;
                  existing.orders += orders;
                  existing.gmv += gmv;
                  existing.gmvWithCoupon += gmvWithCoupon;
                  existing.productShowCount += showCount;
                  existing.productClickCount += clickCount;
                  existing.videoPlayCount += videoPlayCount;
                } else {
                  allMaterials.set(materialId, {
                    advertiserId: account.advertiser_id, materialId, title: videoName,
                    cost, orders, gmv, costPerOrder, roi, gmvWithCoupon,
                    productShowCount: showCount, productClickCount: clickCount,
                    productCtr: ctr, productConvertRate: convertRate,
                    videoPlayCount, videoFinishRate
                  });
                }
              }

              const pageInfo = (res.data && res.data.page_info) ? res.data.page_info : {};
              const total = pageInfo.total_number || 0;
              if (page * 200 >= total) { hasMore = false; }
              page++;
            }
          }
        }
      }
      logger.info('[Sync] 直播账户 ' + account.advertiser_id + ' 获取到 ' + allMaterials.size + ' 个素材');
      // 重算合并后的ROI和订单成本
      for (const [mid, m] of allMaterials) {
        m.roi = m.cost > 0 ? m.gmv / m.cost : 0;
        m.costPerOrder = m.orders > 0 ? m.cost / m.orders : 0;
      }
    } catch (e) {
      logger.error('[Sync] 直播账户素材数据获取失败', { error: e.message, stack: e.stack });
    }
  } else {
    // 商品推广账户使用原有逻辑
  try {
    let page = 1;
    let hasMore = true;
    while (hasMore) {
      const res = await api.getVideoMaterialReport({
        advertiserId: account.advertiser_id,
        startDate: dateStr,
        endDate: dateStr,
        page,
        pageSize: 200
      });

      const rows = (res && res.data && res.data.rows) ? res.data.rows : [];
      if (rows.length === 0) { hasMore = false; break; }

      for (const row of rows) {
        const dims = row.dimensions || {};
        const mets = row.metrics || {};

        const materialId = dims.material_id ? String(dims.material_id.ValueStr || dims.material_id.Value || '') : '';
        const videoName = dims.roi2_material_video_name ? String(dims.roi2_material_video_name.ValueStr || dims.roi2_material_video_name.Value || '') : '';

        if (!materialId || materialId === '-2' || materialId === '0') continue;

        const getVal = (key) => {
          const m = mets[key];
          return m ? (m.Value || 0) : 0;
        };

        const orders = parseInt(getVal('total_pay_order_count_for_roi2')) || 0;
        const gmv = parseFloat(getVal('total_pay_order_gmv_for_roi2')) || 0;
        const costPerOrder = parseFloat(getVal('total_cost_per_pay_order_for_roi2')) || 0;
        const roi = parseFloat(getVal('total_prepay_and_pay_order_roi2')) || 0;
        const gmvWithCoupon = parseFloat(getVal('total_pay_order_gmv_include_coupon_for_roi2')) || 0;
        // 消耗 = stat_cost_for_roi2 优先，否则推算
        const statCostRoi2 = parseFloat(getVal("stat_cost_for_roi2")) || 0;
        const cost = statCostRoi2 > 0 ? statCostRoi2 : (roi > 0 ? gmv / roi : costPerOrder * orders);

        // New metrics: show/click/ctr/convert/play/finish
        const productShowCount = parseInt(getVal("product_show_count_for_roi2")) || 0;
        const productClickCount = parseInt(getVal("product_click_count_for_roi2")) || 0;
        const productCtr = parseFloat(getVal("product_cvr_rate_for_roi2")) || 0;
        const productConvertRate = parseFloat(getVal("product_convert_rate_for_roi2")) || 0;
        const videoPlayCount = parseInt(getVal("video_play_count_for_roi2_v2")) || 0;
        const videoFinishRate = parseFloat(getVal("video_play_finish_rate_for_roi2_v2")) || 0;

        allMaterials.set(materialId, {
          advertiserId: account.advertiser_id,
          materialId,
          title: videoName,
          cost, orders, gmv, costPerOrder, roi, gmvWithCoupon,
          productShowCount, productClickCount, productCtr, productConvertRate,
          videoPlayCount, videoFinishRate
        });
      }

      const pageInfo = (res.data && res.data.page_info) ? res.data.page_info : {};
      const total = pageInfo.total_number || 0;
      if (page * 200 >= total) { hasMore = false; }
      page++;
    }
  } catch (e) {
    logger.warn('[Sync] 素材数据获取失败', { error: e.message });
  }
  } // end else (product accounts)

  // 写入数据库
  let count = 0;
  for (const [materialId, m] of allMaterials) {
    try {
      await db.query(
        'INSERT INTO qc_material_stats (advertiser_id,material_id,stat_date,material_type,title,cost,pay_order_count,pay_order_amount,convert_cost,roi,product_show_count,product_click_count,product_ctr,product_convert_rate,video_play_count,video_finish_rate,show_cnt,click_cnt,ctr,convert_rate,play_cnt) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?) ON DUPLICATE KEY UPDATE title=VALUES(title),cost=VALUES(cost),pay_order_count=VALUES(pay_order_count),pay_order_amount=VALUES(pay_order_amount),convert_cost=VALUES(convert_cost),roi=VALUES(roi),product_show_count=VALUES(product_show_count),product_click_count=VALUES(product_click_count),product_ctr=VALUES(product_ctr),product_convert_rate=VALUES(product_convert_rate),video_play_count=VALUES(video_play_count),video_finish_rate=VALUES(video_finish_rate),show_cnt=VALUES(show_cnt),click_cnt=VALUES(click_cnt),ctr=VALUES(ctr),convert_rate=VALUES(convert_rate),play_cnt=VALUES(play_cnt),updated_at=NOW()',
        [m.advertiserId, m.materialId, dateStr, 'VIDEO', m.title, m.cost, m.orders, m.gmv, m.costPerOrder, m.roi, m.productShowCount, m.productClickCount, m.productCtr, m.productConvertRate, m.videoPlayCount, m.videoFinishRate, m.productShowCount, m.productClickCount, m.productCtr, m.productConvertRate, m.videoPlayCount]
      );
      count++;
    } catch (e) {
      logger.warn('[Sync] 素材写入失败 material_id=' + materialId, { error: e.message });
    }
  }

  logger.info('[Sync] 素材数据同步完成 账户 ' + account.advertiser_id + '，共 ' + count + ' 条素材');
}

async function checkAlerts() {
  const [rules] = await db.query('SELECT * FROM alert_rules WHERE enabled=1');
  if (!rules.length) return;
  const today = dayjs().format('YYYY-MM-DD');
  for (const rule of rules) {
    try {
      const [stats] = await db.query(
        'SELECT entity_id, entity_name, ' + rule.metric + ' AS val FROM qc_daily_stats WHERE stat_date=? AND entity_type=?',
        [today, rule.entity_type]
      );
      for (const stat of stats) {
        const val = parseFloat(stat.val);
        let triggered = false;
        if (rule.operator === 'gt'  && val >  rule.threshold) triggered = true;
        if (rule.operator === 'lt'  && val <  rule.threshold) triggered = true;
        if (rule.operator === 'gte' && val >= rule.threshold) triggered = true;
        if (rule.operator === 'lte' && val <= rule.threshold) triggered = true;
        if (triggered) {
          await db.query(
            'INSERT INTO alert_history (rule_id,entity_id,entity_name,metric,actual_value,threshold_value,message) VALUES (?,?,?,?,?,?,?)',
            [rule.id, stat.entity_id, stat.entity_name, rule.metric, val, rule.threshold,
             rule.name + ': ' + stat.entity_name + ' 当前' + rule.metric + '=' + val + ' ' + rule.operator + ' ' + rule.threshold]
          );
          await sendAlert(rule, stat, val);
          await db.query('UPDATE alert_rules SET last_triggered_at=NOW() WHERE id=?', [rule.id]);
        }
      }
    } catch (e) {
      logger.error('[Alert] 规则' + rule.id + '检查失败', { error: e.message });
    }
  }
}

async function syncAll() {
  const accounts = await getActiveAccounts();
  const today = dayjs().format('YYYY-MM-DD');
  for (const account of accounts) {
    if (account.account_type === "live") {
      await syncLiveDailyStats(account, today);
    } else {
      await syncDailyStats(account, today);
    }
    await syncMaterialStats(account, today);
  }
  await checkAlerts();
}


/**
 * 同步素材封面图和视频URL（需要 /file/video/ad/get/ 授权）
 */
/**
 * 同步素材封面图和视频URL
 * 使用 /v1.0/qianchuan/video/get/ API（已授权）
 */
/**
 * 同步素材封面图和视频URL
 * 使用 /v1.0/qianchuan/video/get/ API
 * 注意：使用原始JSON解析避免BigInt精度丢失
 */
async function syncMaterialCovers() {
  const axios = require('axios');
  const accounts = await getActiveAccounts();
  let total = 0;
  
  for (const account of accounts) {
    try {
      // 获取该账户需要同步封面的material_id集合
      const [needCovers] = await db.query(
        "SELECT DISTINCT material_id FROM qc_material_stats WHERE advertiser_id=? AND (cover_url IS NULL OR cover_url = '')",
        [account.advertiser_id]
      );
      if (!needCovers.length) {
        logger.info('[Sync] 账户 ' + account.advertiser_id + ' 无需同步封面');
        continue;
      }
      const needSet = new Set(needCovers.map(r => String(r.material_id)));
      logger.info('[Sync] 账户 ' + account.advertiser_id + ' 需同步 ' + needSet.size + ' 个素材封面');
      
      let page = 1;
      let hasMore = true;
      let accountUpdated = 0;
      
      while (hasMore && page <= 100) {
        try {
          // 用原始JSON响应避免BigInt精度丢失
          const res = await axios.get('https://ad.oceanengine.com/open_api/v1.0/qianchuan/video/get/', {
            params: { advertiser_id: String(account.advertiser_id), page, page_size: 20 },
            headers: { 'Access-Token': account.access_token },
            transformResponse: [data => data]
          });
          
          const rawJson = res.data;
          const parsed = JSON.parse(rawJson);
          
          if (parsed.code !== 0 || !parsed.data || !parsed.data.list) {
            logger.warn('[Sync] API error page ' + page, { code: parsed.code, msg: parsed.message });
            break;
          }
          
          const list = parsed.data.list;
          const totalPages = Math.ceil((parsed.data.page_info?.total_number || 0) / 20);
          
          // 从原始JSON提取精确的material_id（正则匹配每个视频对象）
          // 方法：分割JSON为每个视频对象，然后提取material_id
          const materialIdMatches = rawJson.match(/"material_id":\s*(\d+)/g) || [];
          const posterMatches = rawJson.match(/"poster_url":\s*"([^"]+)"/g) || [];
          const urlMatches = rawJson.match(/"url":\s*"([^"]+)"/g) || [];
          const vidIdMatches = rawJson.match(/"id":\s*"(v[^"]+)"/g) || [];
          
          for (let i = 0; i < list.length && i < materialIdMatches.length; i++) {
            const rawMid = materialIdMatches[i].replace(/"material_id":\s*/, '');
            
            if (needSet.has(rawMid)) {
              const posterUrl = list[i].poster_url || '';
              const videoUrl = list[i].url || '';
              const videoId = list[i].id || '';
              
              if (posterUrl || videoUrl) {
                await db.query(
                  "UPDATE qc_material_stats SET cover_url=?, video_url=?, video_id=? WHERE material_id=? AND advertiser_id=?",
                  [posterUrl, videoUrl, videoId, rawMid, account.advertiser_id]
                );
                needSet.delete(rawMid);
                accountUpdated++;
                total++;
              }
            }
          }
          
          hasMore = page < totalPages && needSet.size > 0;
          page++;
          
          // 如果所有需要的都找到了就提前结束
          if (needSet.size === 0) break;
          
        } catch (e) {
          logger.warn('[Sync] 分页请求失败 page=' + page, { error: e.message });
          break;
        }
      }
      logger.info('[Sync] 账户 ' + account.advertiser_id + ' 封面同步完成，更新 ' + accountUpdated + ' 条，剩余 ' + needSet.size + ' 未匹配');
    } catch (e) {
      logger.warn('[Sync] 账户 ' + account.advertiser_id + ' 封面同步失败', { error: e.message });
    }
  }
  logger.info('[Sync] 封面同步完成，共更新 ' + total + ' 条');
  return total;
}




module.exports = { syncAll, syncDailyStats, syncLiveDailyStats, syncMaterialStats, syncMaterialCovers, checkAlerts, getActiveAccounts };
