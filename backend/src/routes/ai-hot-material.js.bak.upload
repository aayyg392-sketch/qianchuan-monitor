// ===================== TTS语音合成+视频合并 =====================
async function addTTSToVideo(videoUrl, voiceoverText, dbId) {
  try {
    const { MsEdgeTTS, OUTPUT_FORMAT } = require('msedge-tts');

    const ttsDir = path.join(TTS_DIR, 'hot_' + dbId);
    fs.mkdirSync(ttsDir, { recursive: true });

    const tts = new MsEdgeTTS();
    await tts.setMetadata('zh-CN-XiaoxiaoNeural', OUTPUT_FORMAT.AUDIO_24KHZ_96KBITRATE_MONO_MP3);
    const ttsResult = await tts.toFile(ttsDir, voiceoverText);
    const ttsPath = ttsResult.audioFilePath;
    logger.info('[AIHotMaterial] TTS生成完成 id=' + dbId);

    if (!fs.existsSync(VIDEO_DIR)) fs.mkdirSync(VIDEO_DIR, { recursive: true });
    const tmpVideo = path.join(VIDEO_DIR, 'hot_tmp_' + dbId + '.mp4');
    const finalVideo = path.join(VIDEO_DIR, 'hot_final_' + dbId + '.mp4');

    // 下载即梦视频
    const videoResp = await axios.get(videoUrl, { responseType: 'stream' });
    const writer = fs.createWriteStream(tmpVideo);
    videoResp.data.pipe(writer);
    await new Promise((resolve, reject) => { writer.on('finish', resolve); writer.on('error', reject); });

    // 获取TTS音频时长
    let ttsDur = 5;
    try {
      const td = execSync('ffprobe -v quiet -show_entries format=duration -of csv=p=0 "' + ttsPath + '"', { timeout: 5000 }).toString().trim();
      ttsDur = Math.min(parseFloat(td) || 5, 5.5);
    } catch(e) {}

    // ffmpeg合并
    execSync(
      'ffmpeg -y -i "' + tmpVideo + '" -i "' + ttsPath + '" -t ' + ttsDur + ' -map 0:v -map 1:a -c:v libx264 -preset fast -crf 23 -c:a aac -b:a 128k -r 30 -movflags +faststart -shortest "' + finalVideo + '"',
      { timeout: 60000 }
    );
    logger.info('[AIHotMaterial] 音视频合并完成 id=' + dbId);

    if (fs.existsSync(tmpVideo)) fs.unlinkSync(tmpVideo);
    return '/generated-videos/hot_final_' + dbId + '.mp4';
  } catch (e) {
    logger.error('[AIHotMaterial] TTS合并失败 id=' + dbId, { error: e.message });
    return videoUrl;
  }
}

// ===================== 核心流水线 =====================
async function runPipeline(batchId) {
  logger.info('[AIHotMaterial] 流水线开始 ' + batchId);

  const periodEnd = dayjs().format('YYYY-MM-DD');
  const periodStart = dayjs().subtract(15, 'day').format('YYYY-MM-DD');

  let [hotMaterials] = await db.query(`
    SELECT material_id, title,
      SUM(cost) AS total_cost, SUM(pay_order_count) AS orders, SUM(pay_order_amount) AS gmv,
      CASE WHEN SUM(cost)>0 THEN ROUND(SUM(pay_order_amount)/SUM(cost), 2) ELSE 0 END AS roi,
      ROUND(AVG(CASE WHEN cost >= 100 THEN product_ctr END), 2) AS avg_ctr,
      ROUND(AVG(CASE WHEN cost >= 100 THEN convert_rate END), 2) AS avg_cvr,
      ROUND(AVG(CASE WHEN cost >= 100 THEN play_duration_3s_rate END), 2) AS avg_3s_rate,
      ROUND(AVG(CASE WHEN cost >= 100 THEN play_over_rate END), 2) AS avg_finish_rate,
      MAX(video_duration) AS duration
    FROM qc_material_stats WHERE stat_date >= ? AND cost > 0
    GROUP BY material_id, title HAVING SUM(cost) >= 5000
    ORDER BY SUM(cost) DESC LIMIT 20
  `, [periodStart]);

  if (hotMaterials.length === 0) {
    [hotMaterials] = await db.query(`
      SELECT material_id, title, SUM(cost) AS total_cost, SUM(pay_order_count) AS orders,
        CASE WHEN SUM(cost)>0 THEN ROUND(SUM(pay_order_amount)/SUM(cost), 2) ELSE 0 END AS roi,
        ROUND(AVG(product_ctr), 2) AS avg_ctr, ROUND(AVG(convert_rate), 2) AS avg_cvr,
        ROUND(AVG(play_duration_3s_rate), 2) AS avg_3s_rate
      FROM qc_material_stats WHERE stat_date >= ? AND cost > 0
      GROUP BY material_id, title HAVING SUM(cost) >= 1000
      ORDER BY SUM(cost) DESC LIMIT 10
    `, [periodStart]);
    if (hotMaterials.length === 0) { logger.warn('[AIHotMaterial] 无数据'); return; }
  }

  const hotText = hotMaterials.map((m, i) =>
    `${i+1}. 「${m.title}」 消耗:¥${parseFloat(m.total_cost||0).toFixed(0)} | 成交:${m.orders}单 | ROI:${m.roi} | CTR:${parseFloat(m.avg_ctr||0).toFixed(2)}% | 转化率:${parseFloat(m.avg_cvr||0).toFixed(2)}% | 3s留存:${parseFloat(m.avg_3s_rate||0).toFixed(2)}%`
  ).join('\n');

  const scripts = await generateScripts(hotText, hotMaterials.length, periodStart, periodEnd);

  for (let i = 0; i < scripts.length; i++) {
    const script = scripts[i];
    const [insertResult] = await db.query(
      `INSERT INTO ai_hot_materials (batch_id, script_index, script_type, script_title, script_content, analysis_summary, analysis_data, pipeline_status)
       VALUES (?, ?, ?, ?, ?, ?, ?, 'generating')`,
      [batchId, i + 1, script.type, script.title, JSON.stringify(script), hotText, JSON.stringify(hotMaterials)]
    );
    const dbId = insertResult.insertId;

    try {
      // 分段生成视频：每个scene独立生成，最后拼接
      const scenes = script.scenes || [];
      const segmentUrls = [];
      const segmentVoiceovers = [];
      
      for (let si = 0; si < scenes.length; si++) {
        const scene = scenes[si];
        const scenePrompt = scene.ccr_prompt || scene.description || script.title;
        // 解析时长：从 "0-10s" 提取秒数
        const timeMatch = scene.time?.match(/(\d+)-(\d+)/);
        const sceneDuration = timeMatch ? Math.min(Math.max(parseInt(timeMatch[2]) - parseInt(timeMatch[1]), 5), 10) : 10;
        
        logger.info(`[AIHotMaterial] 生成分镜 #${i+1}-${si+1}/${scenes.length}`, { duration: sceneDuration });
        
        try {
          const taskId = await jimeng.submitText2Video(scenePrompt, { duration: Math.min(sceneDuration, 10) });
          const videoUrl = await jimeng.waitForVideo(taskId);
          segmentUrls.push(videoUrl);
          if (scene.voiceover) segmentVoiceovers.push(scene.voiceover);
          logger.info(`[AIHotMaterial] 分镜完成 #${i+1}-${si+1}`, { videoUrl: videoUrl?.substring(0, 50) });
        } catch (segErr) {
          logger.warn(`[AIHotMaterial] 分镜失败 #${i+1}-${si+1}`, { error: segErr.message });
          // 继续其他分镜
        }
      }
      
      if (segmentUrls.length === 0) throw new Error('所有分镜生成失败');
      
      // 拼接分段视频
      const path = require('path');
      const { execSync } = require('child_process');
      const tmpDir = '/tmp/hot_material_' + dbId;
      execSync(`mkdir -p ${tmpDir}`);
      
      // 下载所有分段
      for (let si = 0; si < segmentUrls.length; si++) {
        execSync(`curl -s -o ${tmpDir}/seg_${si}.mp4 "${segmentUrls[si]}"`, { timeout: 30000 });
      }
      
      // 创建拼接列表
      const concatList = segmentUrls.map((_, si) => `file '${tmpDir}/seg_${si}.mp4'`).join('\n');
      require('fs').writeFileSync(`${tmpDir}/concat.txt`, concatList);
      
      // ffmpeg拼接
      const mergedFile = `${tmpDir}/merged.mp4`;
      execSync(`ffmpeg -y -f concat -safe 0 -i ${tmpDir}/concat.txt -c copy ${mergedFile}`, { timeout: 60000 });
      
      // TTS语音合成
      const voiceoverText = segmentVoiceovers.join('，');
      let finalUrl;
      
      if (voiceoverText) {
        try {
          // 生成TTS音频
          const { MsEdgeTTS } = require('msedge-tts');
          const tts = new MsEdgeTTS();
          await tts.setMetadata('zh-CN-XiaoxiaoNeural', { rate: '+5%', pitch: '+0Hz' });
          const ttsFile = `${tmpDir}/tts.mp3`;
          const readable = tts.toStream(voiceoverText);
          const writeStream = require('fs').createWriteStream(ttsFile);
          await new Promise((resolve, reject) => { readable.pipe(writeStream); writeStream.on('finish', resolve); writeStream.on('error', reject); });
          
          // 合并音频到视频
          const finalFile = `${tmpDir}/final.mp4`;
          execSync(`ffmpeg -y -i ${mergedFile} -i ${ttsFile} -c:v copy -c:a aac -map 0:v:0 -map 1:a:0 -shortest ${finalFile}`, { timeout: 60000 });
          
          // 上传到服务器静态目录
          const outputName = `hot_${dbId}_${Date.now()}.mp4`;
          const outputDir = '/home/www/qianchuan-monitor/backend/public/videos';
          execSync(`mkdir -p ${outputDir} && cp ${finalFile} ${outputDir}/${outputName}`);
          finalUrl = `/videos/${outputName}`;
          logger.info(`[AIHotMaterial] TTS拼接完成 #${i+1}`, { segments: segmentUrls.length });
        } catch (ttsErr) {
          logger.warn(`[AIHotMaterial] TTS失败，使用无声拼接视频 #${i+1}`, { error: ttsErr.message });
          const outputName = `hot_${dbId}_${Date.now()}.mp4`;
          const outputDir = '/home/www/qianchuan-monitor/backend/public/videos';
          execSync(`mkdir -p ${outputDir} && cp ${mergedFile} ${outputDir}/${outputName}`);
          finalUrl = `/videos/${outputName}`;
        }
      } else {
        const outputName = `hot_${dbId}_${Date.now()}.mp4`;
        const outputDir = '/home/www/qianchuan-monitor/backend/public/videos';
        execSync(`mkdir -p ${outputDir} && cp ${mergedFile} ${outputDir}/${outputName}`);
        finalUrl = `/videos/${outputName}`;
      }
      
      // 清理临时文件
      execSync(`rm -rf ${tmpDir}`);
      
      await db.query('UPDATE ai_hot_materials SET jimeng_task_id = ? WHERE id = ?', ['multi_segment', dbId]);
      await db.query("UPDATE ai_hot_materials SET video_url = ?, pipeline_status = 'ready' WHERE id = ?", [finalUrl, dbId]);
    } catch (e) {
      logger.error(`[AIHotMaterial] 生成失败 #${i+1}`, { error: e.message });
      await db.query("UPDATE ai_hot_materials SET pipeline_status = 'failed', error_msg = ? WHERE id = ?", [e.message, dbId]);
    }
  }

  if (global.wsBroadcast) global.wsBroadcast({ type: 'ai_hot_material', event: 'pipeline_done', batchId });
  logger.info('[AIHotMaterial] 流水线完成 ' + batchId);
}

// ===================== AI生成脚本 =====================
async function generateScripts(hotText, hotCount, start, end) {
  const apiKey = process.env.OPENAI_API_KEY;
  const baseUrl = process.env.OPENAI_BASE_URL || 'https://api.aiclaude.xyz/v1';
  const model = process.env.OPENAI_MODEL || 'gpt-5';

  const prompt = `你是雪玲妃品牌（百合氨基酸控油洁面乳/绿泥控油洁面乳）的抖音千川爆款素材创作专家。

## 核心规则（必须严格遵守）
1. **禁止出现产品画面**：因为AI无法准确生成雪玲妃产品外观，脚本和CCR画面描述中绝对不要出现"产品瓶身""包装""logo""标签"等产品相关画面。只描述人物、皮肤状态、使用动作、效果对比。
2. **脚本时长60-90秒**：完整带货短视频脚本，包含6-8个分镜段落。
3. **每个分镜10-15秒**：每段有独立的画面描述和口播文案。
4. **真实UGC风格**：像真人自拍vlog，不要广告感，不要棚拍感。手机手持、浴室/卧室/洗手间场景。
5. **画面只拍人**：面部特写、手部动作、皮肤状态对比（出油→清爽）、使用泡沫洗脸的动作。不拍产品。

## 素材快报洞察
- 特征：短平快直给卖点（500g大容量/温和清洁/油皮友好）、口播实测+近景质地/清洁对比、首屏强钩子
- 建议：15-20秒三段式开头（强钩子→实测对比→利益点），画面高亮白底，手部出泡/纸巾吸油对比

## 爆款素材数据（${hotCount}个，${start} ~ ${end}）
${hotText}

## 生成要求
生成3条60-90秒完整脚本。每条必须：
1. 符合巨量千川"优质素材"标准：前3秒强钩子、使用效果展示、有效CTA
2. 时长60-90秒，竖屏9:16
3. 参考爆款素材的高CTR和高转化话术特征
4. 6-8个分镜，每个分镜10-15秒
5. 口播话术要口语化、真实、有感染力，像闺蜜推荐
6. 画面描述只涉及人物动作和皮肤状态，禁止出现产品

3条脚本分别针对：
- 第1条：高转化型（type: high_convert）— 侧重使用效果和性价比
- 第2条：高CTR型（type: ctr_boost）— 侧重前3秒爆点和视觉冲击
- 第3条：痛点共鸣型（type: pain_point）— 侧重皮肤问题和解决方案

请严格按以下JSON格式输出（不要加markdown代码块标记）：
[
  {
    "type": "high_convert",
    "title": "脚本标题（10字以内）",
    "hook": "前3秒强钩子文案",
    "duration": 75,
    "scenes": [
      {"time": "0-10s", "description": "只描述人物和动作，不提产品。例：年轻女生浴室镜前素颜自拍，T区明显出油反光，皱眉摸脸", "voiceover": "姐妹们你们看我这个T区，油到能煎鸡蛋了", "ccr_prompt": "竖屏9:16。浴室镜前，20岁中国女生素颜自拍，面部T区油光明显，手指点额头，皱眉表情，手机手持拍摄，自然光，真实UGC风格"},
      {"time": "10-20s", "description": "...", "voiceover": "...", "ccr_prompt": "竖屏9:16。..."},
      {"time": "20-35s", "description": "...", "voiceover": "...", "ccr_prompt": "竖屏9:16。..."},
      {"time": "35-50s", "description": "...", "voiceover": "...", "ccr_prompt": "竖屏9:16。..."},
      {"time": "50-65s", "description": "...", "voiceover": "...", "ccr_prompt": "竖屏9:16。..."},
      {"time": "65-75s", "description": "...", "voiceover": "...", "ccr_prompt": "竖屏9:16。..."}
    ],
    "key_selling_points": ["卖点1", "卖点2"],
    "cta": "行动号召语"
  }
]`;

  if (!apiKey) return getDefaultScripts();

  try {
    const resp = await axios.post(`${baseUrl}/chat/completions`, {
      model,
      messages: [{ role: 'user', content: prompt }],
      max_tokens: 8000, temperature: 0.8,
    }, { headers: { 'Authorization': `Bearer ${apiKey}` }, timeout: 90000 });

    const content = resp.data.choices?.[0]?.message?.content || '';
    const jsonMatch = content.match(/\[[\s\S]*\]/);
    if (jsonMatch) {
      const scripts = JSON.parse(jsonMatch[0]);
      if (Array.isArray(scripts) && scripts.length >= 3) return scripts.slice(0, 3);
    }
    return getDefaultScripts();
  } catch (e) {
    logger.error('[AIHotMaterial] AI脚本生成失败', { error: e.message });
    return getDefaultScripts();
  }
}

