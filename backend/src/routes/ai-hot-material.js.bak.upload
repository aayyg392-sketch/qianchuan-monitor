const express = require('express');
const router = express.Router();
const db = require('../db');
const auth = require('../middleware/auth');
const logger = require('../logger');
const axios = require('axios');
const dayjs = require('dayjs');
const jimeng = require('../services/jimeng');
const QianChuanAPI = require('../services/qianchuan');
const path = require('path');
const fs = require('fs');
const { execSync } = require('child_process');

const TTS_DIR = '/home/www/qianchuan-monitor/tts-cache';
const VIDEO_DIR = '/home/www/qianchuan-monitor/generated-videos';

// ===================== 建表 =====================
(async () => {
  try {
    await db.query(`
      CREATE TABLE IF NOT EXISTS ai_hot_materials (
        id INT AUTO_INCREMENT PRIMARY KEY,
        batch_id VARCHAR(50) NOT NULL,
        script_index INT DEFAULT 0,
        script_type VARCHAR(30) DEFAULT '',
        script_title VARCHAR(200) DEFAULT '',
        script_content JSON,
        analysis_summary LONGTEXT,
        analysis_data JSON,
        jimeng_task_id VARCHAR(100) DEFAULT '',
        video_url VARCHAR(500) DEFAULT '',
        video_duration INT DEFAULT 5,
        pipeline_status ENUM('analyzing','scripting','generating','auditing','ready','pushed','tracking','completed','failed') DEFAULT 'analyzing',
        error_msg TEXT,
        audit_score INT DEFAULT 0,
        audit_passed TINYINT(1) DEFAULT 0,
        audit_detail JSON,
        pushed_accounts JSON,
        push_status VARCHAR(20) DEFAULT '',
        qc_material_ids JSON,
        total_cost DECIMAL(12,2) DEFAULT 0,
        total_orders INT DEFAULT 0,
        total_gmv DECIMAL(12,2) DEFAULT 0,
        avg_roi DECIMAL(6,2) DEFAULT 0,
        avg_ctr DECIMAL(6,4) DEFAULT 0,
        is_hot TINYINT(1) DEFAULT 0,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
        INDEX idx_batch (batch_id),
        INDEX idx_status (pipeline_status),
        INDEX idx_hot (is_hot)
      ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4
    `);
    await db.query(`
      CREATE TABLE IF NOT EXISTS ai_hot_material_daily_stats (
        id INT AUTO_INCREMENT PRIMARY KEY,
        material_db_id INT NOT NULL,
        qc_material_id VARCHAR(50),
        stat_date DATE,
        cost DECIMAL(12,2) DEFAULT 0,
        pay_order_count INT DEFAULT 0,
        pay_order_amount DECIMAL(12,2) DEFAULT 0,
        ctr DECIMAL(6,4) DEFAULT 0,
        convert_rate DECIMAL(6,4) DEFAULT 0,
        roi DECIMAL(6,2) DEFAULT 0,
        play_3s_rate DECIMAL(6,4) DEFAULT 0,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        UNIQUE KEY uk_mid_date (material_db_id, stat_date),
        INDEX idx_date (stat_date)
      ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4
    `);
    await db.query(`
      CREATE TABLE IF NOT EXISTS ai_hot_optimization_log (
        id INT AUTO_INCREMENT PRIMARY KEY,
        batch_id VARCHAR(50) NOT NULL,
        iteration INT DEFAULT 1,
        optimization_insight LONGTEXT,
        applied_changes TEXT,
        prev_avg_cost DECIMAL(12,2) DEFAULT 0,
        new_avg_cost DECIMAL(12,2) DEFAULT 0,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP
      ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4
    `);
    logger.info('[AIHotMaterial] 表结构就绪');
  } catch (e) {
    logger.error('[AIHotMaterial] 建表失败', { error: e.message });
  }
})();

// ===================== 仪表盘统计 =====================
router.get('/dashboard', auth(), async (req, res) => {
  try {
    const [[stats]] = await db.query(`
      SELECT
        COUNT(DISTINCT batch_id) AS total_batches,
        COUNT(*) AS total_materials,
        SUM(CASE WHEN pipeline_status IN ('ready','pushed','tracking','completed') THEN 1 ELSE 0 END) AS success_count,
        SUM(CASE WHEN pipeline_status IN ('pushed','tracking','completed') THEN 1 ELSE 0 END) AS pushed_count,
        SUM(CASE WHEN pipeline_status IN ('tracking','completed') THEN 1 ELSE 0 END) AS tracking_count,
        SUM(CASE WHEN is_hot=1 THEN 1 ELSE 0 END) AS hot_count,
        COALESCE(SUM(total_cost), 0) AS total_cost,
        CASE WHEN SUM(total_cost)>0 THEN ROUND(SUM(total_gmv)/SUM(total_cost), 2) ELSE 0 END AS avg_roi
      FROM ai_hot_materials
    `);
    const [[today]] = await db.query(
      'SELECT COUNT(DISTINCT batch_id) AS today_batches FROM ai_hot_materials WHERE DATE(created_at) = CURDATE()'
    );
    res.json({ code: 0, data: { ...stats, today_batches: today.today_batches } });
  } catch (e) {
    res.json({ code: 500, msg: e.message });
  }
});

// ===================== 列表 =====================
router.get('/list', auth(), async (req, res) => {
  try {
    const page = Math.max(1, parseInt(req.query.page) || 1);
    const pageSize = Math.min(50, parseInt(req.query.pageSize) || 10);
    const status = req.query.status || '';
    const offset = (page - 1) * pageSize;
    let where = '1=1';
    const params = [];
    if (status) { where += ' AND pipeline_status = ?'; params.push(status); }
    const [[{ total }]] = await db.query(`SELECT COUNT(*) AS total FROM ai_hot_materials WHERE ${where}`, params);
    const [list] = await db.query(
      `SELECT id, batch_id, script_index, script_type, script_title, pipeline_status,
              video_url, audit_score, audit_passed, total_cost, total_orders, avg_roi, avg_ctr, is_hot,
              push_status, created_at, updated_at
       FROM ai_hot_materials WHERE ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`,
      [...params, pageSize, offset]
    );
    res.json({ code: 0, data: { list, total, page, pageSize } });
  } catch (e) {
    res.json({ code: 500, msg: e.message });
  }
});

// ===================== 详情 =====================
router.get('/detail/:id', auth(), async (req, res) => {
  try {
    const [rows] = await db.query('SELECT * FROM ai_hot_materials WHERE id = ?', [req.params.id]);
    if (!rows.length) return res.json({ code: 404, msg: '不存在' });
    const row = rows[0];
    ['script_content','analysis_data','audit_detail','pushed_accounts','qc_material_ids'].forEach(f => {
      if (typeof row[f] === 'string') try { row[f] = JSON.parse(row[f]); } catch(e) {}
    });
    const [dailyStats] = await db.query(
      'SELECT * FROM ai_hot_material_daily_stats WHERE material_db_id = ? ORDER BY stat_date', [row.id]
    );
    row.daily_stats = dailyStats;
    res.json({ code: 0, data: row });
  } catch (e) {
    res.json({ code: 500, msg: e.message });
  }
});

// ===================== 一键生成 =====================
router.post('/generate', auth(), async (req, res) => {
  const batchId = `hot_${dayjs().format('YYYYMMDDHHmmss')}_${Math.random().toString(36).slice(2,6)}`;
  res.json({ code: 0, msg: '流水线启动', data: { batchId } });
  runPipeline(batchId).catch(e => {
    logger.error('[AIHotMaterial] pipeline failed', { batchId, error: e.message });
  });
});

// ===================== 查询批次状态 =====================
router.get('/status/:batchId', auth(), async (req, res) => {
  try {
    const [rows] = await db.query(
      'SELECT id, script_index, script_title, pipeline_status, video_url, audit_score, error_msg FROM ai_hot_materials WHERE batch_id = ? ORDER BY script_index',
      [req.params.batchId]
    );
    const allDone = rows.length > 0 && rows.every(r => ['ready','pushed','tracking','completed','failed'].includes(r.pipeline_status));
    res.json({ code: 0, data: { items: rows, completed: allDone } });
  } catch (e) {
    res.json({ code: 500, msg: e.message });
  }
});

// ===================== 推送到千川 =====================
router.post('/push/:id', auth(), async (req, res) => {
  try {
    const [rows] = await db.query('SELECT * FROM ai_hot_materials WHERE id = ?', [req.params.id]);
    if (!rows.length) return res.json({ code: 404, msg: '不存在' });
    if (!rows[0].video_url) return res.json({ code: 400, msg: '视频未生成' });
    res.json({ code: 0, msg: '开始推送' });
    pushToQianchuan(rows[0]).catch(e => logger.error('[AIHotMaterial] push failed', { error: e.message }));
  } catch (e) {
    res.json({ code: 500, msg: e.message });
  }
});

// ===================== 批量推送 =====================
router.post('/push-batch/:batchId', auth(), async (req, res) => {
  try {
    const [rows] = await db.query(
      "SELECT * FROM ai_hot_materials WHERE batch_id = ? AND pipeline_status = 'ready' AND video_url != ''",
      [req.params.batchId]
    );
    if (!rows.length) return res.json({ code: 400, msg: '无可推送素材' });
    res.json({ code: 0, msg: `开始推送${rows.length}个素材` });
    for (const item of rows) {
      await pushToQianchuan(item).catch(e => logger.error('[AIHotMaterial] push failed', { id: item.id, error: e.message }));
    }
  } catch (e) {
    res.json({ code: 500, msg: e.message });
  }
});

