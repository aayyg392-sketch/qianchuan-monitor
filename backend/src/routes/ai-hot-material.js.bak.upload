// ===================== 推送到千川 =====================
async function pushToQianchuan(item) {
  logger.info('[AIHotMaterial] 推送 #' + item.id);
  await db.query("UPDATE ai_hot_materials SET pipeline_status = 'pushed', push_status = 'pushing' WHERE id = ?", [item.id]);

  const [accounts] = await db.query("SELECT * FROM qc_accounts WHERE status = 'active'");
  const pushedAccounts = [];
  const materialIds = [];

  for (const acc of accounts) {
    try {
      const api = new QianChuanAPI(acc.access_token);
      const videoDir = VIDEO_DIR;
      if (!fs.existsSync(videoDir)) fs.mkdirSync(videoDir, { recursive: true });
      const localPath = path.join(videoDir, 'push_' + item.id + '_' + Date.now() + '.mp4');

      // 判断是本地路径还是远程URL
      if (item.video_url.startsWith('/generated-videos/')) {
        const srcPath = '/home/www/qianchuan-monitor' + item.video_url;
        fs.copyFileSync(srcPath, localPath);
      } else {
        const videoResp = await axios.get(item.video_url, { responseType: 'stream' });
        const writer = fs.createWriteStream(localPath);
        videoResp.data.pipe(writer);
        await new Promise((resolve, reject) => { writer.on('finish', resolve); writer.on('error', reject); });
      }

      const result = await api.uploadVideo(acc.advertiser_id, localPath, 'AI_' + item.script_title + '_' + item.id);
      if (result && result.video_id) {
        materialIds.push(result.video_id);
        pushedAccounts.push({ advertiser_id: acc.advertiser_id, name: acc.name, video_id: result.video_id });
      }
      fs.unlinkSync(localPath);
    } catch (e) {
      pushedAccounts.push({ advertiser_id: acc.advertiser_id, name: acc.name, error: e.message });
    }
  }

  await db.query(
    "UPDATE ai_hot_materials SET pushed_accounts = ?, qc_material_ids = ?, push_status = 'done', pipeline_status = 'tracking' WHERE id = ?",
    [JSON.stringify(pushedAccounts), JSON.stringify(materialIds), item.id]
  );
}

// ===================== 重试（分镜生成） =====================
async function retryItem(item) {
  try {
    const scriptContent = typeof item.script_content === 'string' ? JSON.parse(item.script_content) : item.script_content;
    await db.query("UPDATE ai_hot_materials SET pipeline_status = 'generating', error_msg = '' WHERE id = ?", [item.id]);
    const dbId = item.id;

    const scenes = scriptContent?.scenes || [];

    // 有分镜则走分段生成
    if (scenes.length > 1) {
      const segmentUrls = [];
      const segmentVoiceovers = [];

      for (let si = 0; si < scenes.length; si++) {
        const scene = scenes[si];
        const scenePrompt = scene.ccr_prompt || scene.description || scriptContent.title;
        const timeMatch = scene.time?.match(/(\d+)-(\d+)/);
        const sceneDuration = timeMatch ? Math.min(Math.max(parseInt(timeMatch[2]) - parseInt(timeMatch[1]), 5), 10) : 10;

        logger.info(`[AIHotMaterial] 重试分镜 #${dbId}-${si+1}/${scenes.length}`, { duration: sceneDuration });

        try {
          const taskId = await jimeng.submitText2Video(scenePrompt, { duration: Math.min(sceneDuration, 10) });
          const videoUrl = await jimeng.waitForVideo(taskId);
          segmentUrls.push(videoUrl);
          if (scene.voiceover) segmentVoiceovers.push(scene.voiceover);
          logger.info(`[AIHotMaterial] 重试分镜完成 #${dbId}-${si+1}`, { videoUrl: videoUrl?.substring(0, 50) });
        } catch (segErr) {
          logger.warn(`[AIHotMaterial] 重试分镜失败 #${dbId}-${si+1}`, { error: segErr.message });
        }
      }

      if (segmentUrls.length === 0) throw new Error('所有分镜生成失败');

      const tmpDir = '/tmp/hot_material_retry_' + dbId;
      execSync(`mkdir -p ${tmpDir}`);

      for (let si = 0; si < segmentUrls.length; si++) {
        execSync(`curl -s -o ${tmpDir}/seg_${si}.mp4 "${segmentUrls[si]}"`, { timeout: 30000 });
      }

      const concatList = segmentUrls.map((_, si) => `file '${tmpDir}/seg_${si}.mp4'`).join('\n');
      fs.writeFileSync(`${tmpDir}/concat.txt`, concatList);

      const mergedFile = `${tmpDir}/merged.mp4`;
      execSync(`ffmpeg -y -f concat -safe 0 -i ${tmpDir}/concat.txt -c copy ${mergedFile}`, { timeout: 60000 });

      const voiceoverText = segmentVoiceovers.join('，');
      let finalUrl;

      if (voiceoverText) {
        try {
          const { MsEdgeTTS } = require('msedge-tts');
          const tts = new MsEdgeTTS();
          await tts.setMetadata('zh-CN-XiaoxiaoNeural', { rate: '+5%', pitch: '+0Hz' });
          const ttsFile = `${tmpDir}/tts.mp3`;
          const readable = tts.toStream(voiceoverText);
          const writeStream = fs.createWriteStream(ttsFile);
          await new Promise((resolve, reject) => { readable.pipe(writeStream); writeStream.on('finish', resolve); writeStream.on('error', reject); });

          const finalFile = `${tmpDir}/final.mp4`;
          execSync(`ffmpeg -y -i ${mergedFile} -i ${ttsFile} -c:v copy -c:a aac -map 0:v:0 -map 1:a:0 -shortest ${finalFile}`, { timeout: 60000 });

          const outputName = `hot_${dbId}_${Date.now()}.mp4`;
          const outputDir = '/home/www/qianchuan-monitor/backend/public/videos';
          execSync(`mkdir -p ${outputDir} && cp ${finalFile} ${outputDir}/${outputName}`);
          finalUrl = `/videos/${outputName}`;
        } catch (ttsErr) {
          logger.warn(`[AIHotMaterial] 重试TTS失败，使用无声视频`, { error: ttsErr.message });
          const outputName = `hot_${dbId}_${Date.now()}.mp4`;
          const outputDir = '/home/www/qianchuan-monitor/backend/public/videos';
          execSync(`mkdir -p ${outputDir} && cp ${mergedFile} ${outputDir}/${outputName}`);
          finalUrl = `/videos/${outputName}`;
        }
      } else {
        const outputName = `hot_${dbId}_${Date.now()}.mp4`;
        const outputDir = '/home/www/qianchuan-monitor/backend/public/videos';
        execSync(`mkdir -p ${outputDir} && cp ${mergedFile} ${outputDir}/${outputName}`);
        finalUrl = `/videos/${outputName}`;
      }

      execSync(`rm -rf ${tmpDir}`);
      await db.query('UPDATE ai_hot_materials SET jimeng_task_id = ? WHERE id = ?', ['multi_segment', dbId]);
      await db.query("UPDATE ai_hot_materials SET video_url = ?, pipeline_status = 'ready' WHERE id = ?", [finalUrl, dbId]);
      logger.info(`[AIHotMaterial] 重试完成 #${dbId}`, { segments: segmentUrls.length });
    } else {
      // 无分镜，单段生成
      const prompt = scriptContent?.ccr_prompt || scriptContent?.title || 'beauty product video';
      const taskId = await jimeng.submitText2Video(prompt, { duration: scriptContent?.duration || 5 });
      await db.query('UPDATE ai_hot_materials SET jimeng_task_id = ? WHERE id = ?', [taskId, dbId]);
      const videoUrl = await jimeng.waitForVideo(taskId);

      const voiceText = scenes.map(s => s.voiceover || '').filter(Boolean).join('，') || scriptContent?.hook || '';
      let finalUrl = videoUrl;
      if (voiceText) {
        try { finalUrl = await addTTSToVideo(videoUrl, voiceText, dbId); } catch(e) { /* 静默失败 */ }
      }
      await db.query("UPDATE ai_hot_materials SET video_url = ?, pipeline_status = 'ready' WHERE id = ?", [finalUrl, dbId]);
    }
  } catch (e) {
    logger.error(`[AIHotMaterial] 重试失败 #${item.id}`, { error: e.message });
    await db.query("UPDATE ai_hot_materials SET pipeline_status = 'failed', error_msg = ? WHERE id = ?", [e.message, item.id]);
  }
}

// ===================== 启动恢复：自动重试卡住的任务 =====================
setTimeout(async () => {
  try {
    const [stuck] = await db.query(
      "SELECT * FROM ai_hot_materials WHERE pipeline_status = 'generating' AND updated_at < DATE_SUB(NOW(), INTERVAL 5 MINUTE)"
    );
    if (stuck.length > 0) {
      logger.info(`[AIHotMaterial] 发现 ${stuck.length} 个卡住的任务，自动重试`);
      for (const item of stuck) {
        logger.info(`[AIHotMaterial] 自动重试 #${item.id} "${item.script_title}"`);
        retryItem(item).catch(e => logger.error('[AIHotMaterial] 自动重试失败', { id: item.id, error: e.message }));
        // 串行执行，避免即梦API并发限制
        await new Promise(r => setTimeout(r, 2000));
      }
    }
  } catch (e) {
    logger.error('[AIHotMaterial] 启动恢复检查失败', { error: e.message });
  }
}, 10000); // 启动10秒后检查

// ===================== 同步投放数据 =====================
async function syncTrackingData() {
  const [items] = await db.query(
    "SELECT id, qc_material_ids, pushed_accounts FROM ai_hot_materials WHERE pipeline_status IN ('tracking','pushed') AND qc_material_ids IS NOT NULL"
  );
  if (!items.length) return;

  const [accounts] = await db.query("SELECT * FROM qc_accounts WHERE status = 'active'");
  if (!accounts.length) return;

  const today = dayjs().format('YYYY-MM-DD');
  const weekAgo = dayjs().subtract(7, 'day').format('YYYY-MM-DD');

  for (const item of items) {
    const matIds = typeof item.qc_material_ids === 'string' ? JSON.parse(item.qc_material_ids) : item.qc_material_ids;
    if (!matIds || !matIds.length) continue;

    let totalCost = 0, totalOrders = 0, totalGmv = 0;
    for (const acc of accounts) {
      try {
        const api = new QianChuanAPI(acc.access_token);
        const report = await api.getVideoMaterialReport({ advertiserId: acc.advertiser_id, startDate: weekAgo, endDate: today });
        if (report && report.list) {
          for (const row of report.list) {
            if (matIds.includes(row.video_id)) {
              totalCost += parseFloat(row.stat_cost || 0);
              totalOrders += parseInt(row.pay_order_count || 0);
              totalGmv += parseFloat(row.pay_order_amount || 0);
              await db.query(`
                INSERT INTO ai_hot_material_daily_stats (material_db_id, qc_material_id, stat_date, cost, pay_order_count, pay_order_amount, ctr, convert_rate, roi, play_3s_rate)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                ON DUPLICATE KEY UPDATE cost=VALUES(cost), pay_order_count=VALUES(pay_order_count), pay_order_amount=VALUES(pay_order_amount),
                  ctr=VALUES(ctr), convert_rate=VALUES(convert_rate), roi=VALUES(roi), play_3s_rate=VALUES(play_3s_rate)
              `, [item.id, row.video_id, today, row.stat_cost||0, row.pay_order_count||0, row.pay_order_amount||0,
                  row.show_click_rate||0, row.convert_rate||0,
                  row.stat_cost > 0 ? (row.pay_order_amount / row.stat_cost).toFixed(2) : 0,
                  row.play_duration_3s_rate||0]);
            }
          }
        }
      } catch (e) {
        logger.error('[AIHotMaterial] tracking error', { error: e.message });
      }
    }

    const avgRoi = totalCost > 0 ? (totalGmv / totalCost).toFixed(2) : 0;
    const isHot = totalCost >= 100000 ? 1 : 0;
    await db.query('UPDATE ai_hot_materials SET total_cost=?, total_orders=?, total_gmv=?, avg_roi=?, is_hot=? WHERE id=?',
      [totalCost, totalOrders, totalGmv, avgRoi, isHot, item.id]);
    if (isHot) await db.query("UPDATE ai_hot_materials SET pipeline_status='completed' WHERE id=?", [item.id]);
  }
}

module.exports = router;
module.exports.runPipeline = runPipeline;
// === AI创作接口：text2video, text2image, creations, task-status ===
// 追加到 ai-hot-material.js 路由文件末尾

// 文生视频
router.post('/text2video', auth(), async (req, res) => {
  const { prompt, duration = 5, ratio = '9:16', model = 'doubao' } = req.body;
  if (!prompt) return res.json({ code: 400, msg: '请输入提示词' });

  try {
    let taskId, provider;

    if (model === 'doubao') {
      const doubao = require('../services/doubao-seedance');
      taskId = await doubao.submitText2Video(prompt, { duration, ratio });
      provider = 'doubao';
    } else if (model === 'jimeng') {
      taskId = await jimeng.submitText2Video(prompt, { duration, width: ratio === '16:9' ? 1280 : 720, height: ratio === '16:9' ? 720 : 1280 });
      provider = 'jimeng';
    } else if (model === 'kling') {
      // TODO: 可灵接口
      return res.json({ code: 400, msg: '可灵接口暂未接入' });
    } else {
      return res.json({ code: 400, msg: '不支持的模型' });
    }

    // 存入数据库
    await db.query(
      `INSERT INTO ai_creations (type, prompt, model, duration, ratio, task_id, provider, status) VALUES (?,?,?,?,?,?,?,?)`,
      ['video', prompt, model, duration, ratio, taskId, provider, 'processing']
    );
    const [[row]] = await db.query('SELECT LAST_INSERT_ID() as id');

    // 后台轮询任务状态
    pollCreationTask(row.id, taskId, provider, model === 'jimeng' ? 'jimeng_t2v_v30_1080p' : null);

    logger.info('[AI Create] text2video submitted', { taskId, model, id: row.id });
    res.json({ code: 0, data: { taskId: row.id } });
  } catch (e) {
    logger.error('[AI Create] text2video error', { error: e.message });
    res.json({ code: 500, msg: e.message });
  }
});

// 文生图片
router.post('/text2image', auth(), async (req, res) => {
  const { prompt, ratio = '9:16', model = 'doubao' } = req.body;
  if (!prompt) return res.json({ code: 400, msg: '请输入提示词' });

  try {
    let taskId, provider;

    if (model === 'jimeng') {
      // 即梦图片生成
      const resp = await jimeng.callAPI('CVSync2AsyncSubmitTask', {
        req_key: 'high_aes_general_v21_L',
        prompt,
        width: ratio === '16:9' ? 1280 : ratio === '1:1' ? 1024 : 720,
        height: ratio === '16:9' ? 720 : ratio === '1:1' ? 1024 : 1280,
        seed: -1,
        scale: 3.5,
        ddim_steps: 25,
        return_url: true,
      });
      taskId = resp.data?.task_id;
      if (!taskId) throw new Error('No task_id: ' + JSON.stringify(resp));
      provider = 'jimeng';
    } else if (model === 'doubao') {
      // 豆包图片生成 (通过火山方舟 API)
      const apiKey = process.env.DOUBAO_ARK_API_KEY;
      if (!apiKey) throw new Error('未配置 DOUBAO_ARK_API_KEY');
      const r = await axios.post('https://ark.cn-beijing.volces.com/api/v3/images/generations', {
        model: 'doubao-seedance-2-0-pro-260215',
        prompt,
        size: ratio === '16:9' ? '1280x720' : ratio === '1:1' ? '1024x1024' : '720x1280',
        n: 1,
      }, {
        headers: { 'Authorization': `Bearer ${apiKey}`, 'Content-Type': 'application/json' },
        timeout: 60000,
      });
      // 同步返回图片URL
      const imgUrl = r.data?.data?.[0]?.url || r.data?.data?.[0]?.b64_json;
      if (imgUrl) {
        await db.query(
          `INSERT INTO ai_creations (type, prompt, model, ratio, status, result_url) VALUES (?,?,?,?,?,?)`,
          ['image', prompt, model, ratio, 'done', imgUrl]
        );
        const [[row]] = await db.query('SELECT LAST_INSERT_ID() as id');
        return res.json({ code: 0, data: { taskId: row.id } });
      }
      // 如果是异步任务
      taskId = r.data?.id || r.data?.task_id;
      if (!taskId) throw new Error('No result: ' + JSON.stringify(r.data).slice(0, 300));
      provider = 'doubao';
    } else {
      return res.json({ code: 400, msg: '不支持的模型' });
    }

    await db.query(
      `INSERT INTO ai_creations (type, prompt, model, ratio, task_id, provider, status) VALUES (?,?,?,?,?,?,?)`,
      ['image', prompt, model, ratio, taskId, provider, 'processing']
    );
    const [[row]] = await db.query('SELECT LAST_INSERT_ID() as id');

    pollCreationTask(row.id, taskId, provider, provider === 'jimeng' ? 'high_aes_general_v21_L' : null);

    logger.info('[AI Create] text2image submitted', { taskId, model, id: row.id });
    res.json({ code: 0, data: { taskId: row.id } });
  } catch (e) {
    logger.error('[AI Create] text2image error', { error: e.message });
    res.json({ code: 500, msg: e.message });
  }
});

// 查询任务状态
router.get('/task-status/:id', auth(), async (req, res) => {
  try {
    const [[row]] = await db.query('SELECT id, status, result_url FROM ai_creations WHERE id = ?', [req.params.id]);
    if (!row) return res.json({ code: 404, msg: '任务不存在' });
    res.json({ code: 0, data: row });
  } catch (e) {
    res.json({ code: 500, msg: e.message });
  }
});

// 创作记录列表
router.get('/creations', auth(), async (req, res) => {
  const { page = 1, pageSize = 50, type } = req.query;
  try {
    let where = '1=1';
    const params = [];
    if (type) { where += ' AND type = ?'; params.push(type); }
    const [[{ total }]] = await db.query(`SELECT COUNT(*) as total FROM ai_creations WHERE ${where}`, params);
    const [list] = await db.query(
      `SELECT * FROM ai_creations WHERE ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,
      [...params, parseInt(pageSize), (parseInt(page) - 1) * parseInt(pageSize)]
    );
    res.json({ code: 0, data: { list, total } });
  } catch (e) {
    res.json({ code: 500, msg: e.message });
  }
});

// 后台轮询任务
async function pollCreationTask(dbId, taskId, provider, reqKey) {
  const maxAttempts = 60; // 5min max
  let attempt = 0;
  const poll = async () => {
    attempt++;
    if (attempt > maxAttempts) {
      await db.query('UPDATE ai_creations SET status = ?, error_msg = ? WHERE id = ?', ['failed', 'timeout', dbId]);
      return;
    }
    try {
      let result;
      if (provider === 'jimeng') {
        result = await jimeng.queryTask(taskId, reqKey);
      } else if (provider === 'doubao') {
        const doubao = require('../services/doubao-seedance');
        result = await doubao.queryTask(taskId);
      }

      if (result.status === 'done' && (result.videoUrl || result.imageUrl)) {
        const url = result.videoUrl || result.imageUrl;
        await db.query('UPDATE ai_creations SET status = ?, result_url = ? WHERE id = ?', ['done', url, dbId]);
        logger.info('[AI Create] task done', { dbId, url: url.slice(0, 80) });
        return;
      }
      if (result.status === 'failed') {
        await db.query('UPDATE ai_creations SET status = ?, error_msg = ? WHERE id = ?', ['failed', JSON.stringify(result.raw).slice(0, 500), dbId]);
        return;
      }
      setTimeout(poll, 5000);
    } catch (e) {
      logger.warn('[AI Create] poll error', { dbId, error: e.message });
      setTimeout(poll, 5000);
    }
  };
  setTimeout(poll, 3000);
}

// 建表
(async () => {
  try {
    await db.query(`
      CREATE TABLE IF NOT EXISTS ai_creations (
        id INT AUTO_INCREMENT PRIMARY KEY,
        type ENUM('video','image') DEFAULT 'video',
        prompt TEXT,
        model VARCHAR(30) DEFAULT 'doubao',
        duration INT DEFAULT 5,
        ratio VARCHAR(10) DEFAULT '9:16',
        task_id VARCHAR(200) DEFAULT '',
        provider VARCHAR(30) DEFAULT '',
        status ENUM('pending','processing','done','failed') DEFAULT 'pending',
        result_url VARCHAR(1000) DEFAULT '',
        error_msg TEXT,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
        INDEX idx_status (status),
        INDEX idx_type (type)
      ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4
    `);
  } catch (e) { /* table exists */ }
})();

module.exports.syncTrackingData = syncTrackingData;
